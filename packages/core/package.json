  "description": "Framework-neutral Cesium effects SDK for geospatial visualizations.",
  "license": "MIT",
  "author": "zhaohao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzxzhaohao/cesiumDesign.git",
